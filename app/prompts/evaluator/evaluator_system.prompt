  ],
  "areas": [
    {
      "title": "Area Title",
      "bullets": ["bullet 1", "bullet 2"],
      "fix": "One-line fix suggestion.",
      "instead_of": "What the candidate said",
      "say": "What they should say instead"
    }
  ],
  "question_insights": [
    {
      "question": "The question Alex asked",
      "score": 0.0,
      "car_bullets": [
        {"text": "What was good or missing", "status": "good"},
        {"text": "What needs improvement", "status": "warn"}
      ]
    }
  ],
  "coaching_cards": [
    {
      "title": "Coaching Recommendation Title",
      "bullets": ["Actionable tip 1", "Actionable tip 2", "Actionable tip 3"]
    }
  ],
  "hiring_readiness": {
    "technical":      {"rating": "", "positive": false},
